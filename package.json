{
  "name": "web",
  "version": "0.5.3",
  "private": true,
  "packageManager": "yarn@4.5.0",
  "scripts": {
    "build": "nuxi build",
    "dev": "UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.dev.yaml up --build",
    "dev:reset": "docker compose -f docker-compose.dev.yaml down -v && yarn dev",
    "dev:portal": "UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.dev.yaml -f docker-compose.portal.yaml up",
    "generate": "nuxi generate",
    "prepare": "simple-git-hooks && nuxi prepare",
    "preview": "nuxi preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@element-plus/nuxt": "^1.1.5",
    "@sentry/nuxt": "^10.47.0",
    "@teritorio/openstreetmap-logical-history-component": "0.7.0",
    "@turf/bbox": "^7.3.4",
    "@turf/boolean-equal": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@types/geojson": "^7946.0.14",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "element-plus": "^2.13.6",
    "maplibre-gl": "^5.0.0",
    "underscore": "^1.13.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^3.19.1",
    "@nuxtjs/i18n": "^10.2.4",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/underscore": "^1.11.15",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.38.0",
    "happy-dom": "^17.4.4",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "postcss-html": "^1.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vitest": "^3.1.1",
    "vue-tsc": "^3.2.6"
  },
  "resolutions": {
    "diff": "^9.0.0",
    "vue-router": "^5.0.0"
  },
  "simple-git-hooks": {
    "commit-msg": "yarn dlx commitlint --edit $1",
    "pre-commit": "yarn dlx lint-staged",
    "preserveUnused": true
  },
  "lint-staged": {
    "*": "yarn nuxi typecheck .",
    "*.{vue,ts,js}": "yarn lint:fix"
  }
}
