{
  "name": "web",
  "version": "0.4.5",
  "private": true,
  "packageManager": "yarn@4.5.0",
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "prepare": "simple-git-hooks && nuxi prepare",
    "preview": "nuxi preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@element-plus/nuxt": "^1.1.5",
    "@sentry/vue": "^10.45.0",
    "@turf/bbox": "^7.3.4",
    "@turf/boolean-equal": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@types/geojson": "^7946.0.14",
    "dayjs": "^1.11.20",
    "diff": "^8.0.4",
    "element-plus": "^2.13.6",
    "maplibre-gl": "^4.1.2",
    "underscore": "^1.13.6",
    "v-lazy-component": "^3.0.9",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/i18n": "^10.2.4",
    "@types/node": "^22.0.0",
    "@types/underscore": "^1.11.15",
    "babel-jest": "^29.7.0",
    "eslint": "^9.38.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "postcss-html": "^1.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "5.8.3",
    "vue-tsc": "^3.2.6"
  },
  "resolutions": {
    "vue-router": "^5.0.0"
  },
  "simple-git-hooks": {
    "commit-msg": "yarn dlx commitlint --edit $1",
    "pre-commit": "yarn dlx lint-staged",
    "preserveUnused": true
  },
  "lint-staged": {
    "*": "yarn nuxi typecheck .",
    "*.{vue,ts,js}": "yarn lint:fix"
  }
}
